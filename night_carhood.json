{
  "version": 8,
  "name": "Carhood JDM Neon",
  "metadata": {
    "carhood:description": "Tokyo Drift vibe — granatowe niebo, neonowe drogi, Carhood green akcenty na autostradach.",
    "carhood:version": "1.0"
  },
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet"
    }
  },
  "glyphs": "https://fonts.openmaptiles.org/{fontstack}/{range}.pbf",
  "sprite": "https://cdn.jsdelivr.net/gh/simplycodestudio/carhood-public-assets@3d4a8ebc/sprite",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#0A0E27"
      }
    },
    {
      "id": "landcover-glacier",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", "subclass", "glacier"],
      "paint": {
        "fill-color": "#1A2147",
        "fill-opacity": 0.4
      }
    },
    {
      "id": "landcover-wood",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", "class", "wood"],
      "paint": {
        "fill-color": "#142B1A",
        "fill-opacity": 0.7
      }
    },
    {
      "id": "landcover-grass",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", "class", "grass"],
      "paint": {
        "fill-color": "#1A331F",
        "fill-opacity": 0.55
      }
    },
    {
      "id": "landuse-residential",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": ["==", "class", "residential"],
      "paint": {
        "fill-color": "#0D1230",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "landuse-industrial",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": ["==", "class", "industrial"],
      "paint": {
        "fill-color": "#131938",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": {
        "fill-color": "#1B3320",
        "fill-opacity": 0.55
      }
    },
    {
      "id": "park-outline",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": {
        "line-color": "#234A2C",
        "line-width": 0.6,
        "line-opacity": 0.6
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "filter": ["all", ["==", "$type", "Polygon"], ["!=", "intermittent", 1]],
      "paint": {
        "fill-color": "#050817",
        "fill-antialias": true
      }
    },
    {
      "id": "water-river",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#0A1530",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          10, 0.5,
          14, 1.2,
          17, 2
        ]
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 14,
      "paint": {
        "fill-color": "#13183A",
        "fill-opacity": [
          "interpolate", ["linear"], ["zoom"],
          14, 0,
          15, 0.4,
          17, 0.55
        ]
      }
    },
    {
      "id": "building-outline",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 15,
      "paint": {
        "line-color": "#1A2147",
        "line-width": 0.4,
        "line-opacity": [
          "interpolate", ["linear"], ["zoom"],
          15, 0,
          16, 0.25,
          18, 0.4
        ]
      }
    },


    {
      "id": "road-path",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "path", "track"],
      "minzoom": 14,
      "paint": {
        "line-color": "#1A2150",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          14, 0.5,
          18, 1.5
        ],
        "line-dasharray": [2, 2]
      }
    },
    {
      "id": "road-service",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "service"],
      "minzoom": 13,
      "paint": {
        "line-color": "#3A4380",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          13, 0.6,
          18, 3
        ]
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "minor"],
      "paint": {
        "line-color": "#5566B0",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          11, 0.6,
          15, 2,
          18, 6
        ]
      }
    },
    {
      "id": "road-tertiary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "tertiary"],
      "paint": {
        "line-color": "#6B7CC8",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          9, 0.5,
          14, 2.2,
          18, 8
        ]
      }
    },
    {
      "id": "road-secondary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "secondary"],
      "paint": {
        "line-color": "#8090DC",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          8, 0.5,
          14, 2.7,
          18, 10
        ]
      }
    },
    {
      "id": "road-primary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "primary"],
      "paint": {
        "line-color": "#A8B5F0",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          7, 0.7,
          12, 2.2,
          18, 12
        ]
      }
    },
    {
      "id": "road-trunk-glow",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "trunk"],
      "minzoom": 6,
      "paint": {
        "line-color": "#00B8D4",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          6, 1.5,
          12, 5,
          18, 18
        ],
        "line-blur": 2,
        "line-opacity": 0.35
      }
    },
    {
      "id": "road-trunk",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "trunk"],
      "minzoom": 5,
      "paint": {
        "line-color": "#00B8D4",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          5, 0.6,
          12, 2.5,
          18, 12
        ]
      }
    },


    {
      "id": "road-motorway-outer-glow",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "motorway"],
      "minzoom": 5,
      "paint": {
        "line-color": "#00C853",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          5, 2.5,
          10, 6,
          14, 14,
          18, 28
        ],
        "line-blur": 3,
        "line-opacity": 0.22
      }
    },
    {
      "id": "road-motorway-inner-glow",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "motorway"],
      "minzoom": 5,
      "paint": {
        "line-color": "#00E5FF",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          5, 1.6,
          10, 4,
          14, 9,
          18, 18
        ],
        "line-blur": 1.5,
        "line-opacity": 0.45
      }
    },
    {
      "id": "road-motorway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "motorway"],
      "minzoom": 4,
      "paint": {
        "line-color": "#00E5FF",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          4, 0.8,
          10, 2.5,
          14, 5,
          18, 11
        ]
      }
    },


    {
      "id": "rail",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "rail"],
      "minzoom": 11,
      "paint": {
        "line-color": "#353B5C",
        "line-width": 1,
        "line-dasharray": [3, 2]
      }
    },


    {
      "id": "boundary-state",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": ["all", ["==", "admin_level", 4], ["!=", "maritime", 1]],
      "minzoom": 7,
      "paint": {
        "line-color": "#1F2547",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          7, 0.4,
          12, 0.8
        ],
        "line-opacity": [
          "interpolate", ["linear"], ["zoom"],
          7, 0.0,
          9, 0.4,
          14, 0.7
        ],
        "line-dasharray": [4, 3]
      }
    },
    {
      "id": "boundary-country",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": ["all", ["==", "admin_level", 2], ["!=", "maritime", 1]],
      "paint": {
        "line-color": "#3A4480",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          3, 0.5,
          10, 1.4
        ],
        "line-opacity": 0.55
      }
    },


    {
      "id": "water-name",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "water_name",
      "minzoom": 6,
      "layout": {
        "text-field": "{name:latin}",
        "text-font": ["Open Sans Italic"],
        "text-size": 11,
        "text-max-width": 5
      },
      "paint": {
        "text-color": "#5A7AAB",
        "text-halo-color": "#050817",
        "text-halo-width": 1
      }
    },
    {
      "id": "road-label-major",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "minzoom": 12,
      "filter": ["in", "class", "motorway", "trunk", "primary", "secondary"],
      "layout": {
        "symbol-placement": "line",
        "text-field": "{name:latin}",
        "text-font": ["Open Sans Regular"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          12, 10,
          16, 12,
          18, 14
        ],
        "text-letter-spacing": 0.05
      },
      "paint": {
        "text-color": "#A0B0E8",
        "text-halo-color": "#0A0E27",
        "text-halo-width": 1.8
      }
    },
    {
      "id": "road-label-minor",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "minzoom": 15,
      "filter": ["in", "class", "tertiary", "minor"],
      "layout": {
        "symbol-placement": "line",
        "text-field": "{name:latin}",
        "text-font": ["Open Sans Regular"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          15, 10,
          18, 12
        ],
        "text-letter-spacing": 0.04
      },
      "paint": {
        "text-color": "#7B85C0",
        "text-halo-color": "#0A0E27",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-village",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", "class", "village"],
      "minzoom": 10,
      "layout": {
        "text-field": "{name:latin}",
        "text-font": ["Open Sans Regular"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          10, 9,
          14, 12
        ]
      },
      "paint": {
        "text-color": "#8B92BC",
        "text-halo-color": "#0A0E27",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-suburb",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["in", "class", "suburb", "neighbourhood"],
      "minzoom": 13,
      "layout": {
        "text-field": "{name:latin}",
        "text-font": ["Open Sans Regular"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          13, 10,
          16, 13
        ],
        "text-letter-spacing": 0.06,
        "text-transform": "uppercase"
      },
      "paint": {
        "text-color": "#9CA8D8",
        "text-halo-color": "#0A0E27",
        "text-halo-width": 1.6,
        "text-opacity": 0.75
      }
    },
    {
      "id": "place-town",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", "class", "town"],
      "minzoom": 7,
      "layout": {
        "text-field": "{name:latin}",
        "text-font": ["Open Sans Regular"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          7, 11,
          14, 15
        ]
      },
      "paint": {
        "text-color": "#C8CFEC",
        "text-halo-color": "#0A0E27",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-city",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["all", ["==", "class", "city"], [">=", "rank", 4]],
      "minzoom": 5,
      "layout": {
        "text-field": "{name:latin}",
        "text-font": ["Open Sans Bold"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          5, 11,
          10, 16,
          14, 20
        ],
        "text-letter-spacing": 0.04
      },
      "paint": {
        "text-color": "#E8ECFC",
        "text-halo-color": "#0A0E27",
        "text-halo-width": 1.8
      }
    },
    {
      "id": "place-city-large",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["all", ["==", "class", "city"], ["<", "rank", 4]],
      "minzoom": 3,
      "layout": {
        "text-field": "{name:latin}",
        "text-font": ["Open Sans Bold"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          3, 12,
          8, 18,
          14, 24
        ],
        "text-letter-spacing": 0.05
      },
      "paint": {
        "text-color": "#FFFFFF",
        "text-halo-color": "#0A0E27",
        "text-halo-width": 2
      }
    },
    {
      "id": "place-country",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", "class", "country"],
      "minzoom": 2,
      "maxzoom": 6,
      "layout": {
        "text-field": "{name:latin}",
        "text-font": ["Open Sans Bold"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          2, 10,
          6, 16
        ],
        "text-letter-spacing": 0.12,
        "text-transform": "uppercase"
      },
      "paint": {
        "text-color": "#7B8FE0",
        "text-halo-color": "#0A0E27",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "poi-fuel",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "poi",
      "filter": ["all",
        ["==", "class", "fuel"],
        ["!=", "subclass", "charging_station"],
        ["any",
          [">=", ["index-of", "Shell", ["get", "name"]], 0],
          [">=", ["index-of", "Orlen", ["get", "name"]], 0],
          [">=", ["index-of", "BP", ["get", "name"]], 0],
          [">=", ["index-of", "Moya", ["get", "name"]], 0],
          [">=", ["index-of", "Lotos", ["get", "name"]], 0]
        ]
      ],
      "minzoom": 14,
      "layout": {
        "visibility": "none",
        "icon-image": ["case",
          [">=", ["index-of", "Shell", ["get", "name"]], 0], "shell-pin",
          [">=", ["index-of", "Orlen", ["get", "name"]], 0], "orlen-pin",
          [">=", ["index-of", "BP", ["get", "name"]], 0], "bp-pin",
          [">=", ["index-of", "Moya", ["get", "name"]], 0], "moya-pin",
          [">=", ["index-of", "Lotos", ["get", "name"]], 0], "lotos-pin",
          ""
        ],
        "icon-size": [
          "interpolate", ["linear"], ["zoom"],
          14, 0.7,
          16, 0.85,
          18, 1.0
        ],
        "icon-anchor": "bottom",
        "icon-allow-overlap": false,
        "text-field": ["get", "name"],
        "text-font": ["Open Sans Bold"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          14, 10,
          16, 12,
          18, 13
        ],
        "text-max-width": 8,
        "text-padding": 4,
        "text-anchor": "top",
        "text-offset": [0, 0.5]
      },
      "paint": {
        "text-color": ["case",
          [">=", ["index-of", "Shell", ["get", "name"]], 0], "#FFCC00",
          [">=", ["index-of", "Orlen", ["get", "name"]], 0], "#E2231A",
          [">=", ["index-of", "BP", ["get", "name"]], 0], "#009639",
          [">=", ["index-of", "Moya", ["get", "name"]], 0], "#3D8BFF",
          [">=", ["index-of", "Lotos", ["get", "name"]], 0], "#F39200",
          "#FFD54F"
        ],
        "text-halo-color": "#0A0E27",
        "text-halo-width": 2.2
      }
    },
    {
      "id": "poi-carwash",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "poi",
      "filter": ["any",
        ["==", "class", "car_wash"],
        ["==", "subclass", "car_wash"]
      ],
      "minzoom": 15,
      "layout": {
        "visibility": "none",
        "icon-image": "carwash-pin",
        "icon-size": [
          "interpolate", ["linear"], ["zoom"],
          15, 0.7,
          18, 1.0
        ],
        "icon-anchor": "bottom",
        "icon-allow-overlap": false,
        "text-field": "Myjnia",
        "text-font": ["Open Sans Bold"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          15, 10,
          18, 12
        ],
        "text-padding": 4,
        "text-anchor": "top",
        "text-offset": [0, 0.5]
      },
      "paint": {
        "text-color": "#81D4FA",
        "text-halo-color": "#0A0E27",
        "text-halo-width": 2
      }
    },
    {
      "id": "poi-charging",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "poi",
      "filter": ["any",
        ["==", "class", "charging_station"],
        ["==", "subclass", "charging_station"]
      ],
      "minzoom": 14,
      "layout": {
        "visibility": "none",
        "icon-image": "ev-pin",
        "icon-size": [
          "interpolate", ["linear"], ["zoom"],
          14, 0.7,
          18, 1.0
        ],
        "icon-anchor": "bottom",
        "icon-allow-overlap": false,
        "text-field": ["coalesce", ["get", "name"], "Ładowanie EV"],
        "text-font": ["Open Sans Bold"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          14, 10,
          18, 13
        ],
        "text-max-width": 8,
        "text-padding": 4,
        "text-anchor": "top",
        "text-offset": [0, 0.5]
      },
      "paint": {
        "text-color": "#D580FF",
        "text-halo-color": "#0A0E27",
        "text-halo-width": 2
      }
    }
  ]
}
